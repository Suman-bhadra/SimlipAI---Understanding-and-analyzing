{
  "manifest_version": 3,
  "name": "SimplifAI",
  "description": "Simplify research papers, PDFs, websites and YouTube videos using AI.",
  "version": "1.0.0",

  "permissions": [
    "activeTab",
    "storage",
    "contextMenus",
    "scripting"
  ],

  "host_permissions": [
    "http://localhost:5000/*"
  ],

  "background": {
    "service_worker": "src/background/background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/content.js"
      ]
    }
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "SimplifAI"
  }

  
}